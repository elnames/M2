FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y     gcc libpq-dev curl wget gnupg     libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0     libcups2 libdrm2 libxkbcommon0 libxcomposite1     libxdamage1 libxfixes3 libxrandr2 libgbm1     libasound2 libpango-1.0-0 libcairo2     && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Instalar browser de Playwright (Chromium)
RUN playwright install chromium --with-deps 2>/dev/null || echo 'Playwright browser opcional'

COPY . .

EXPOSE 3050

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "3050"]
