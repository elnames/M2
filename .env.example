# ============================================================
# m2.nmsdev.tech — Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# --- Base de Datos PostgreSQL ---
DB_USER=clave_user
DB_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/clave_inmo

# --- NextAuth v5 ---
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://tu-dominio.com

# --- Google OAuth (opcional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Resend (emails de magic link y alertas) ---
# Obtén tu API key en: https://resend.com
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=alertas@tu-dominio.com

# --- Comunicación interna entre contenedores ---
DATA_ENGINE_URL=http://data-engine:3050
